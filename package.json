{
  "name": "dialekto",
  "version": "2.1.34",
  "description": "Dialekto · Web-App zum Lernen deutscher Dialekte. Karteikarten, SRS, Quiz, Vergleich, PWA — komplett ohne Backend.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npx --yes http-server@14 . -p 5173 -c-1 -o --gzip --brotli",
    "validate": "node tools/validate.mjs",
    "dedupe": "node tools/dedupe.mjs",
    "sync-version": "node tools/sync-version.mjs",
    "export-mobile-data": "node tools/export-mobile-data.mjs",
    "test": "node tools/test.mjs",
    "test:coverage": "node tools/test.mjs --coverage",
    "test:integration": "node tools/test.mjs --filter=integration",
    "test:frontend": "node tools/test.mjs --filter=frontend",
    "a11y": "node tools/a11y-audit.mjs",
    "security": "node tools/security-scan.mjs",
    "bundle-analyze": "node tools/bundle-analyze.mjs",
    "minify-css": "node tools/minify-css.mjs",
    "build": "node tools/minify-css.mjs && node tools/export-mobile-data.mjs",
    "install-hooks": "node tools/install-hooks.mjs",
    "ci": "npm run validate && npm run a11y && npm run security && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tounsii007/dialekt-lernen.git"
  },
  "homepage": "https://github.com/tounsii007/dialekt-lernen#readme",
  "bugs": {
    "url": "https://github.com/tounsii007/dialekt-lernen/issues"
  },
  "license": "Apache-2.0"
}
