# === Dialekto · Docker-Konfiguration (Vorlage) ===
# Kopiere diese Datei zu ".env" und passe sie an.
# In PRODUKTION zwingend das Datenbank-Passwort ändern!

# ── Öffentlicher Host-Port (im Browser) — bewusst nicht 80/8080 ──
FRONTEND_PORT=8973             # Web-App: http://localhost:8973

# ── Interne Container-Ports (nur im Docker-Netz; bewusst nicht die Defaults) ──
NGINX_PORT=8080                # nginx im Frontend-Container
BACKEND_PORT=9090              # Spring-Boot-Backend (Standard wäre 8080)
POSTGRES_PORT=6432             # PostgreSQL (Standard wäre 5432)

# ── Skalierung ──
BACKEND_REPLICAS=2             # Backend-Instanzen; nginx verteilt per Round-Robin

# ── Datenbank ──
POSTGRES_DB=dialekto
POSTGRES_USER=dialekto
POSTGRES_PASSWORD=dialekto-bitte-aendern

# ── Backend ──
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
CORS_ORIGINS=http://localhost:8973

# ── Nur für das Debug-Override (docker-compose.debug.yml) ──
# direkter Zugriff auf Backend/DB; bei Backend-Direktzugriff BACKEND_REPLICAS=1 setzen.
BACKEND_DEBUG_PORT=19090
POSTGRES_DEBUG_PORT=65432
